# Database
DATABASE_URL=postgresql+asyncpg://fastrouter:fastrouter@localhost:5432/fastrouter

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for provider keys at rest)
ENCRYPTION_KEY=change-me-32-bytes-key-here!!  # Must be 32 bytes for AES-256

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # $19/month subscription

# LiteLLM Proxy
LITELLM_URL=http://localhost:4000

# Free tier
FREE_REQUESTS_LIMIT=1000

# App
APP_ENV=development
DEBUG=true
